IMPLEMENTATION MODULE DB;

IMPORT Lib, rs2, Process, TimeDate;

(*
VAR
    Buffer  :  ARRAY [ 0..54000 ] OF BYTE;
    Size    :  CARDINAL;
    At      :  CARDINAL;
*)

CONST
    Baud  =  9600;


PROCEDURE TxProcess;
(* Send Tx over rs2 port *)
BEGIN

    LOOP
        WHILE rs2.TxCount() > 0 DO END;
        Process.Delay( 8 );
(*        Lib.Delay( 20000 DIV Baud );
        rs2.Break( 40000 DIV Baud ); *)
        rs2.Send( Buffer, Size );
    END (* LOOP *);

END TxProcess;

PROCEDURE InstallTx;
BEGIN
    rs2.Install( 2 );
    rs2.Init( Baud, 8, rs2.None, TRUE, FALSE );
    Size := 0;
    Process.StartScheduler;
    Process.StartProcess( TxProcess, 4096, 1 );
END InstallTx;

TYPE  BufType = ARRAY [ 0..54000 ] OF BYTE;

VAR  K  :  CHAR;
     RxBuf   : ARRAY [ 0..8000 ] OF BYTE;
     RxSize  :  CARDINAL;

PROCEDURE RxProcess;
(* Get Rx over rs2 port *)
BEGIN

    (* Wait for sync *)
    WHILE ~rs2.BreakTest() DO
        IF rs2.RxCount() > 0 THEN
            rs2.Receive( K, 1 );
        END (* IF *);
    END (* WHILE *);
    LOOP
        (* Now receive until next sync *)
        At := 0;
        WHILE ~rs2.BreakTest() DO
            WHILE rs2.RxCount() > 0 DO
                RxSize := rs2.RxCount();
                rs2.Receive( RxBuf, RxSize );
                IF Lib.Compare( ADR( Buffer[ At ] ), ADR( RxBuf ),
                    RxSize ) < RxSize THEN
                    NewFile := TRUE;
                    Lib.Move( ADR( RxBuf ), ADR( Buffer[ At ]), RxSize );
                    At := At+RxSize;
                    Size := At;
                    Lib.Fill( ADR( Buffer[ Size+1 ] ), 54000-Size, 0 );
                ELSE
                    Lib.Move( ADR( RxBuf ), ADR( Buffer[ At ]), RxSize );
                    At := At+RxSize;
                END (* IF *);
            END (* WHILE *);
        END (* WHILE *);
        Size := At;

    END (* LOOP *);

END RxProcess;

PROCEDURE InstallRx;
BEGIN
    rs2.Install( 2 );
    rs2.Init( Baud, 8, rs2.None, TRUE, FALSE );

    DB.NewFile := FALSE;
    DB.Size := 0;
    DB.At := 0;
    Process.StartScheduler;
    Process.StartProcess( RxProcess, 4096, 1 );
END InstallRx;

(*
PROCEDURE LoadTxBuffer( PicTime : TimeDate.Time;
                        Range, Gain, Tilt  :  BYTE;
                        Data : ARRAY OF BYTE;
                        DataSize : CARDINAL );
BEGIN
    Lib.Move( ADR(PicTime), ADR(Buffer), 6 );
    Buffer[ 6 ] := Range;
    Buffer[ 7 ] := Gain;
    Buffer[ 8 ] := Tilt;
    Lib.Move( ADR(Data), ADR(Buffer[9]), DataSize );
    Size := DataSize+9;
END LoadTxBuffer;


PROCEDURE LoadRxBuffer( VAR Data : ARRAY OF BYTE );
BEGIN
END LoadRxBuffer;
*)

END DB.