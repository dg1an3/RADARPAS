  FROM SYSTEM IMPORT ADDRESS;

  TYPE
    CompressError = (NoCompressError, AllocationFailed,
        CompressedTooLarge, Corruption);

  VAR
    ErrorFlag: CompressError;

  PROCEDURE Compress(InAddress: ADDRESS; InSize:
      CARDINAL; VAR OutAddress: ADDRESS; VAR OutSize:
      CARDINAL; OutAlloc: BOOLEAN): BOOLEAN;

  PROCEDURE Decompress(InAddress: ADDRESS; InSize:
      CARDINAL; OutAddress: ADDRESS; OutSize:
      CARDINAL);

END MemCompress.
