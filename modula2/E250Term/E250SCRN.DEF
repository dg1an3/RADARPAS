DEFINITION MODULE E250Scrn;

(*********************************************************)
(* Created   : 11/14/90                                  *)
(* Last Edit : 11/14/90                                  *)
(* Author    : Derek Lane                                *)
(* System    : TopSpeed Modula-2                         *)
(*                                                       *)
(* Screen handler for radar terminal.  Controls most     *)
(* elements of the screen.                               *)
(*********************************************************)

FROM SYSTEM IMPORT ADDRESS;
FROM TimeDate IMPORT Time;


TYPE
    MapEntry  =  RECORD
        CASE  :  CARDINAL OF
            1  :
                Bear, Range  :  CARDINAL;
                Ident  :  ARRAY [ 0..2 ] OF CHAR;
                Space  :  CHAR;  |
            2  :
                Range1, Bear1,
                Range2, Bear2  :  CARDINAL;  |
            3  :
                EndFlag  :  LONGCARD;  |
        END (* CASE *);
    END (* RECORD *);

    Map  =  ARRAY [ 0..1023 ] OF MapEntry;



PROCEDURE WriteRngMks;

VAR
  ScrnMap : ARRAY [ 1..1 ] OF Map;
  CurrRange, CurrTilt  :  CARDINAL;


PROCEDURE WriteMap( Number : CARDINAL );


VAR
  CX, CY  :  CARDINAL;


PROCEDURE WriteRangeBear( X, Y : INTEGER );


PROCEDURE DrawCursor;


PROCEDURE DrawScale;


PROCEDURE ClearScreen;


VAR
    FullScreen  :  BOOLEAN;

PROCEDURE WritePic( VAR Buffer : ARRAY OF BYTE;
                    BufSize  :  CARDINAL;
                    VAR SrcAt, DestAt, P  :  CARDINAL );


PROCEDURE ToggleGraphics;


PROCEDURE Message(String : ARRAY OF CHAR);
(* Prints message at bottom of screen.  Call Message('') to turn off *)

PROCEDURE Prompt(String : ARRAY OF CHAR; VAR Response : ARRAY OF CHAR);
(* Prints String and then reads in Response *)

PROCEDURE Pause(String : ARRAY OF CHAR) : CHAR;
(* Prints String and waits for a key press, then returns key pressed *)


END E250Scrn.
