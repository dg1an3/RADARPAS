 data.
========================================================
*)

FROM SYSTEM IMPORT
  BYTE;
EXPORT QUALIFIED
  CalcCRC;

PROCEDURE CalcCRC
( ForBuffer : ARRAY OF BYTE;
  VAR CRC   : CARDINAL);

END CRC.
