ECHO OFF
IF NOT %1==FORMAT GOTO NOFORMAT

REM *** DISK FORMATTING ***
:RETRY
ECHO Insert your system disk in drive B:
PAUSE
IF NOT EXIST B:FORMAT.COM GOTO RETRY
ECHO Beginning disk format.
B:FORMAT B:/S/V
DELETE A:FORMAT.COM
COPY A:AUTOEXEC.BAT B:AUTOEXEC.BAT

REM *** COPY RADAR.COM PROGRAM TO DRIVE B:
:NOFORMAT
COPY A:RADAR.COM B:RADAR.COM
:END
