DEFINITION MODULE ScreenHandler;

(*********************************************************)
(* Created   : 1/26/87                                   *)
(* Last Edit : 2/9/87                                    *)
(* Author    : Derek Lane                                *)
(* System    : LOGITECH MODULA-2/86                      *)
(*                                                       *)
(* Screen handler for radar terminal.  Controls most     *)
(* elements of the screen.                               *)
(*********************************************************)

FROM SYSTEM IMPORT ADDRESS;
FROM TimeDate IMPORT Time;

EXPORT QUALIFIED
  ArmyTime, WriteTime, WriteDate,
  WriteTilt, WriteRange, WriteGain,
  WriteParams,
  SetMap,
  ToggleRangeMarks, ToggleMap,
  Redraw,
  Message, Prompt, Pause;

VAR
  ArmyTime : BOOLEAN;
(* Set to TRUE to write time in 24 hour format, FALSE for am/pm format *)

PROCEDURE WriteTime(ForTime : Time);
(* Writes the time in 7 spaces, with am/pm if ArmyTime is TRUE *)

PROCEDURE WriteDate(ForTime : Time);
(* Writes the date in 8 spaces *)

PROCEDURE WriteTilt(Tilt : CARDINAL);
(* Writes the tilt in 2 spaces, right justified *)

PROCEDURE WriteRange(Range : CARDINAL);
(* Writes the range in 3 spaces, right justified. 
   Writing the range sets the range for map drawing,
   and causes any maps to be redrawn. *)

PROCEDURE WriteGain(Gain : CARDINAL);
(* Writes the gain in 3 spaces, right justified *)

PROCEDURE WriteParams(Tilt, Range, Gain : CARDINAL; ForTime : Time);
(* Writes the parameters in the four screen corners.  If maps are
   on, redraws them to new range. *)

PROCEDURE SetMap(Number : CARDINAL; At : ADDRESS);
(* Sets map number Number at indicated location *)
                 
PROCEDURE ToggleRangeMarks;
PROCEDURE ToggleMap(Number : CARDINAL);
(* Toggles the indicated screen element on or off *)

PROCEDURE Redraw;
(* Redraws the maps and range marks at indicated range *)

PROCEDURE Message(String : ARRAY OF CHAR);
(* Prints message at bottom of screen.  Call Message('') to turn off *)

PROCEDURE Prompt(String : ARRAY OF CHAR; VAR Response : ARRAY OF CHAR);
(* Prints String and then reads in Response *)

PROCEDURE Pause(String : ARRAY OF CHAR) : CHAR;
(* Prints String and waits for a key press, then returns key pressed *)

END ScreenHandler.
