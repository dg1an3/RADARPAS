DEFINITION MODULE Modem;

(*            C R E A T E D  : 12/11/86
 *        L A S T   E D I T  : 2/9/86
 *              A U T H O R  : Derek Lane
 *              S Y S T E M  : LOGITECH MODULA-2/86
 *
 *  Interface to a Hayes-comaptible modem.  Dialing, auto
 *  redial, and response as to how the call is progress-
 *  ing.
 *)

EXPORT QUALIFIED
  ResultCode, Call, HangUp, ModemCommand;

TYPE
  ResultCode =           (* Result of a modem operation:           *)
    ( Ok,                (*   Command accepted and processed       *)
      Connect300,        (*   Dial command successfully connected
                                at 300 baud                        *)
      Ring,              (*   Ringing                              *)
      NoCarrier,         (*   No data carrier detected             *)
      ModemError,        (*   Unknown command                      *)
      Connect1200,       (*   Dial command successfully connected  
                                at 1200 baud                       *)
      NoDialtone,        (*   Modem probably not hooked to line    *)
      Busy,              (*   Busy signal detected                 *)
      NoAnswer,          (*   Phone rang, but no answer detected   *)
      Connect2400,       (*   Dial command successfully connected  
                                at 2400 baud                       *)
      NoResponse );      (*   Modem isn't responding to commands   *)

PROCEDURE Call
( Number     : ARRAY OF CHAR;
  VAR Result : ResultCode );
(* Dials the number Number (which may contain Hayes dial modifiers) and
   sets Result accordingly. *)

PROCEDURE HangUp
( VAR Result : ResultCode );
(* Disconnects line if connected; otherwise, does nothing. *)

PROCEDURE ModemCommand
( Command    : ARRAY OF CHAR;
  VAR Result : ResultCode );
(* Sends AT Command to modem, sets result accordingly. *)

END Modem.
