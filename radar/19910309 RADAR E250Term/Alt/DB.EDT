============================================================
:MainMenu

    Parent Frame: 0    (* Go to DOS on exit *)

    Window:{
        No box
        Position: (1, 1, 80, 25)
    }

(*    Help:{ Banner } *)

    Fields:{
        () 'bytesFree' String
        () 'todaysDate' String
        (V) '' GoTo Banner
        (R) '' GoTo Banner
        (M) '' GoTo Banner
        (U) '' GoTo UtilitiesAndOptions
        (Q) '' GoTo Banner
    }

