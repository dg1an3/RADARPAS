============================================================
:Banner

    Normal Next: MainMenu

    Window:{
        No box
        Position: (1, 256, 80, 256)
    }

    Colors:{
        NormalText = (blue,brightWhite) plain
        PointerBar = (blue,darkGrey) underScored
        Border = (blue,brightWhite) plain
        Prompts = (red,brightWhite) bold
        Messages = (red,brightWhite) bold
        SelectedText = (blue,lightBlue) bold
    }

    Fields:{
        () 'message' String
    }

