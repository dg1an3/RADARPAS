@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix radar: <http://example.org/radarpas/ontology#> .
@prefix src: <http://example.org/radarpas/source#> .

# =============================================================================
# Main Product Modules
# =============================================================================

src:GDEM a radar:Program ;
    rdfs:label "GDEM" ;
    dc:title "Graphical Data Entry Manager" ;
    dc:description "Digital map and geographic data entry tool for acetate/protractor coordinates" ;
    radar:purpose "Line-based map data entry with bearing/range coordinate system" ;
    radar:programmingLanguage "Turbo Pascal" ;
    radar:partOfVersion src:GDEM_v2 .

src:RADARPAS_Main a radar:Program ;
    rdfs:label "RADAR.PAS Main Program" ;
    dc:title "RADARPAS Main Terminal" ;
    dc:description "Weather radar terminal main program for E300 interface" ;
    radar:programmingLanguage "Turbo Pascal" ;
    radar:lineCount 1895 ;
    radar:partOfVersion src:RADARPAS_v2_1 .

src:E300PC a radar:Program ;
    rdfs:label "E300PC" ;
    dc:title "E300PC Radar Terminal" ;
    dc:description "Modula-2 rewrite of RADARPAS for E300 radar" ;
    radar:programmingLanguage "Modula-2" ;
    radar:partOfVersion src:E300PC_v3_1 .

src:E250Term a radar:Program ;
    rdfs:label "E250Term" ;
    dc:title "E250 Terminal System" ;
    dc:description "Terminal program for E250 radar with TSR screen transmission" ;
    radar:programmingLanguage "Modula-2" ;
    radar:partOfVersion src:E250Term_v3 .

# =============================================================================
# Modula-2 Modules - Core
# =============================================================================

src:Module_MAIN a radar:Module ;
    rdfs:label "MAIN" ;
    dc:description "Master control loop and station management" ;
    radar:programmingLanguage "Modula-2" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_MAIN_MOD_1988,    # 1988-08-15 initial port
                    src:File_MAIN_MOD ;         # 1992-12-28 final E300PC 3.1
    radar:imports src:Module_ANALYSIS, src:Module_DB, src:Module_E300INTE,
                  src:Module_GRAPHICS, src:Module_LOCATOR, src:Module_MODEM,
                  src:Module_PICTURES, src:Module_RS, src:Module_SCREENHA,
                  src:Module_SELECTOR, src:Module_STATIONS .

src:Module_ANALYSIS a radar:Module ;
    rdfs:label "ANALYSIS" ;
    dc:description "Real-time storm cell recognition algorithms" ;
    radar:programmingLanguage "Modula-2" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_ANALYSIS_MOD ;     # 1992-10-23
    radar:purpose "Marker tracking and radar analysis" .

src:Module_AUTO a radar:Module ;
    rdfs:label "AUTO" ;
    dc:description "Automated picture capture and processing" ;
    radar:programmingLanguage "Modula-2" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_AUTO_MOD_1988,     # 1988-08-15
                    src:File_AUTO_MOD .          # 1992-10-23

src:Module_CRC a radar:Module ;
    rdfs:label "CRC" ;
    dc:description "Cyclic redundancy check for data integrity" ;
    radar:programmingLanguage "Modula-2" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_CRC_MOD .

src:Module_COMPR a radar:Module ;
    rdfs:label "COMPR" ;
    dc:description "Picture compression/decompression algorithms" ;
    radar:programmingLanguage "Modula-2" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_COMPR_MOD .

src:Module_CONVERT a radar:Module ;
    rdfs:label "CONVERT" ;
    dc:description "Data format conversion utilities" ;
    radar:programmingLanguage "Modula-2" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_CONVERT_MOD .

src:Module_DB a radar:Module ;
