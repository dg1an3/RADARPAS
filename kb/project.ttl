# =============================================================================
# Hardware Context (Schema.org)
# =============================================================================

src:TargetHardware a schema:ComputerHardware ;
    schema:name "IBM PC Compatible" ;
    schema:description "Intel 8088/8086 @ 4.77 MHz, 640 KB RAM, EGA display" .

src:RadarHardware_E300 a schema:Product ;
    schema:name "Ellason E300 Color Weather Radar" ;
    schema:manufacturer "Ellason" .

src:RadarHardware_E250 a schema:Product ;
    schema:name "Ellason E250 Color Weather Radar" ;
    schema:manufacturer "Ellason" .

# =============================================================================
# Technical Specifications
# =============================================================================

src:DisplaySpec a schema:PropertyValue ;
    schema:name "Display Specifications" ;
    schema:value "EGA 640x350, 16 colors, 4 VGA planes" .

src:CommunicationSpec a schema:PropertyValue ;
    schema:name "Communication Specifications" ;
    schema:value "RS-232, 2400 baud, Hayes/Racal-Vadic modem" .
