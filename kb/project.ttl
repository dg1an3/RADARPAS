@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix schema: <http://schema.org/> .
@prefix radar: <http://example.org/radarpas/ontology#> .
@prefix src: <http://example.org/radarpas/source#> .

# =============================================================================
# RADARPAS Project Metadata (Dublin Core aligned)
# =============================================================================

src:RADARPAS a radar:SoftwareProject, schema:SoftwareApplication ;
    dc:title "RADARPAS - Radar Terminal Software" ;
    dc:description """Historical source code archives for weather radar terminal software
    developed in the 1980s-1990s for interfacing IBM PCs with Ellason E300/E250
    Color Weather Radar systems.""" ;
    dc:creator src:DerekLane ;
    dc:publisher "D. G. Lane" ;
    dc:rights "Copyright (C) D. G. Lane, 1987-1998. All rights reserved." ;
    dc:language "en" ;
    dc:type "Software" ;
    dcterms:created "1985"^^xsd:gYear ;
    dcterms:modified "1998"^^xsd:gYear ;
    dcterms:temporal "1985/1998" ;
    schema:programmingLanguage "Turbo Pascal", "Modula-2", "x86 Assembly" ;
    schema:operatingSystem "MS-DOS" ;
    radar:containsModule src:GDEM, src:RADARPAS_Main, src:E300PC, src:E250Term ;
    foaf:homepage <https://github.com/DLaneAtElekta/RADARPAS> .

# =============================================================================
# Creator/Author Information (FOAF)
# =============================================================================

src:DerekLane a foaf:Person ;
    foaf:name "Derek Lane" ;
    foaf:nick "D. G. Lane" ;
    foaf:mbox_sha1sum "author@radarpas" .

