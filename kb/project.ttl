src:RADARPAS_v2_1 a radar:ProductVersion ;
    rdfs:label "RADARPAS 2.1" ;
    dc:title "RADARPAS Final Pascal Version" ;
    radar:versionNumber "2.1" ;
    radar:dateCreated "1988-01-14"^^xsd:date ;
    radar:programmingLanguage "Turbo Pascal" ;
    radar:derivedFrom src:RADARPAS_v2 ;
    prov:wasAttributedTo src:DerekLane .

src:E300PC_v1 a radar:ProductVersion ;
    rdfs:label "E300PC v1" ;
