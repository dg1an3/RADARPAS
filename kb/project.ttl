# Product Versions (Provenance)
# =============================================================================

src:GDEM_v1 a radar:ProductVersion ;
    rdfs:label "GDEM 1.0" ;
    dc:title "Graphical Data Entry Manager" ;
    dc:description "Digital map and geographic data entry tool for acetate/protractor coordinates" ;
    radar:versionNumber "1.0" ;
    radar:dateCreated "1984"^^xsd:gYear ;
    radar:programmingLanguage "Commodore BASIC" ;
    prov:wasAttributedTo src:DerekLane .

src:GDEM_v2 a radar:ProductVersion ;
    rdfs:label "GDEM 2.0" ;
    dc:title "Graphical Data Entry Manager (Pascal Rewrite)" ;
    radar:versionNumber "2.0" ;
    radar:dateCreated "1985"^^xsd:gYear ;
    radar:programmingLanguage "Turbo Pascal" ;
    radar:derivedFrom src:GDEM_v1 ;
    prov:wasAttributedTo src:DerekLane .

