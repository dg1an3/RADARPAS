# =============================================================================
# RS-232 Serial Communication (2400 baud)
# =============================================================================

src:Proc_RS232Interrupt a radar:InterruptHandler ;
    rdfs:label "RS232Interupt" ;
    dc:description "Interrupt service routine for COM port (Pascal ISR)" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:purpose "Handle serial port receive interrupts and buffer data" ;
    radar:firstSeen "1985"^^xsd:gYear ;
    radar:lastSeen "1988-08-01"^^xsd:date ;
    radar:signature "procedure RS232Interupt" .

src:Proc_Tx a radar:Procedure ;
    rdfs:label "Tx" ;
    dc:description "Transmit single character over serial port (Pascal)" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:hasParameter src:Param_Char ;
    radar:firstSeen "1985"^^xsd:gYear ;
    radar:lastSeen "1988-08-01"^^xsd:date ;
    radar:signature "procedure Tx(Charac)" .

src:Proc_TxChar a radar:Procedure ;
    rdfs:label "TxChar" ;
    dc:description "Transmit single character over serial port (M2)" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:renamedFrom src:Proc_Tx ;
    radar:firstSeen "1988-03-29"^^xsd:date ;
    radar:lastSeen "1992-12-28"^^xsd:date ;
    radar:signature "procedure TxChar(C: CHAR)" .

src:Func_Rx a radar:Function ;
    rdfs:label "Rx" ;
    dc:description "Receive character from serial buffer (Pascal)" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:hasReturnType src:Type_Char ;
    radar:firstSeen "1985"^^xsd:gYear ;
    radar:lastSeen "1988-08-01"^^xsd:date ;
    radar:signature "function Rx: Char" .

src:Func_RxChar a radar:Function ;
    rdfs:label "RxChar" ;
    dc:description "Receive character from serial buffer (M2)" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:renamedFrom src:Func_Rx ;
    radar:firstSeen "1988-03-29"^^xsd:date ;
    radar:lastSeen "1992-12-28"^^xsd:date ;
    radar:signature "function RxChar(): CHAR" .

src:Func_RxReady a radar:Function ;
    rdfs:label "RxReady" ;
    dc:description "Check if character available in receive buffer" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:firstSeen "1988-03-29"^^xsd:date ;
    radar:lastSeen "1992-12-28"^^xsd:date ;
    radar:signature "function RxReady(): BOOLEAN" .

src:Func_TxEmpty a radar:Function ;
    rdfs:label "TxEmpty" ;
    dc:description "Check if transmit buffer empty" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:firstSeen "1988-03-29"^^xsd:date ;
    radar:lastSeen "1992-12-28"^^xsd:date ;
    radar:signature "function TxEmpty(): BOOLEAN" .

src:Func_RxCount a radar:Function ;
    rdfs:label "RxCount" ;
    dc:description "Count characters in receive buffer" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:firstSeen "1988-03-29"^^xsd:date ;
    radar:lastSeen "1992-12-28"^^xsd:date ;
    radar:signature "function RxCount(): CARDINAL" .

src:Proc_SetupRxInt a radar:Procedure ;
    rdfs:label "SetupRxInt" ;
    dc:description "Configure receive interrupt (M2 replacement for RS232Interupt)" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:renamedFrom src:Proc_RS232Interrupt ;
    radar:firstSeen "1988-08-15"^^xsd:date ;
    radar:lastSeen "1992-12-28"^^xsd:date ;
