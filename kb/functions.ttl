src:Proc_M2_AddPicture a radar:Procedure ;
    rdfs:label "AddPicture" ;
    dc:description "Insert new picture into sorted position in picture list" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 315 .

src:Proc_M2_DeletePicture a radar:Procedure ;
    rdfs:label "DeletePicture" ;
    dc:description "Delete picture from list and remove corresponding file" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 403 .

src:Proc_M2_WritePictureEntry a radar:Procedure ;
    rdfs:label "WritePictureEntry" ;
    dc:description "Write one entry of picture list (date, time, tilt, range, gain)" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 450 .

src:Proc_M2_PictureMenu a radar:Procedure ;
    rdfs:label "PictureMenu" ;
    dc:description "Menu-driven picture management with select and delete operations" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 479 ;
    radar:calls src:Proc_M2_SelectPicture, src:Proc_M2_DeletePicture .

