src:Proc_RxGraphLoop a radar:Procedure ;
    rdfs:label "RxGraphLoop" ;
    dc:description "Map overlay reception loop" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_ExecCom a radar:Procedure ;
    rdfs:label "ExecCom" ;
    dc:description "Execute radar command" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_RADAR_PAS ;
