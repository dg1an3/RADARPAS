# =============================================================================
# Configuration
# =============================================================================

src:Proc_Config a radar:Procedure ;
    rdfs:label "Config" ;
    dc:description "Display configuration options menu (modem type, port, printer, clock)" ;
    radar:belongsToCategory radar:ConfigCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_Initialize a radar:Procedure ;
    rdfs:label "Initialize" ;
