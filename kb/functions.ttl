# =============================================================================
# RADARPAS Procedures and Functions — Abstract Symbols
# Each symbol represents the logical function across all snapshots.
# Concrete file locations are tracked via SymbolOccurrence in occurrences.ttl.
# =============================================================================

# =============================================================================
# DOS/BIOS Interface Routines (Pascal-only)
# =============================================================================

src:Proc_SetDTA a radar:Procedure ;
    rdfs:label "SetDTA" ;
    dc:description "Set Disk Transfer Area for DOS file operations" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:purpose "Configure DOS DTA pointer for directory operations" ;
    radar:firstSeen "1985"^^xsd:gYear ;
    radar:lastSeen "1988-08-01"^^xsd:date ;
    radar:signature "procedure SetDTA(var DTA)" .

src:Proc_SetDir a radar:Procedure ;
