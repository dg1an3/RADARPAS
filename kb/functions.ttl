# =============================================================================
# RADARPAS Pascal Procedures and Functions
# Organized by Functional Category
# =============================================================================

# =============================================================================
# DOS/BIOS Interface Routines
# =============================================================================

src:Proc_SetDTA a radar:Procedure ;
    rdfs:label "SetDTA" ;
    dc:description "Set Disk Transfer Area for DOS file operations" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:purpose "Configure DOS DTA pointer for directory operations" .

src:Proc_SetDir a radar:Procedure ;
    rdfs:label "SetDir" ;
    dc:description "Initialize directory enumeration" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Func_DirEntry a radar:Function ;
    rdfs:label "DirEntry" ;
    dc:description "Get next directory entry" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasReturnType src:Type_Boolean .

src:Func_ReadKbd a radar:Function ;
    rdfs:label "ReadKbd" ;
    dc:description "Read keyboard input without echo" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasReturnType src:Type_Char .

src:Proc_WriteTime a radar:Procedure ;
    rdfs:label "WriteTime" ;
    dc:description "Format and write time to screen" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_RADAR_PAS .

# =============================================================================
# Graphics Routines (EGA 640x350 @ 16 colors)
# =============================================================================

src:Proc_InitEGA a radar:Procedure ;
    rdfs:label "InitEGA" ;
    dc:description "Initialize EGA graphics mode 0x10 (640x350, 16 colors)" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:purpose "Set up EGA display with 4 VGA planes" .

src:Proc_SelectPlane a radar:Procedure ;
    rdfs:label "SelectPlane" ;
    dc:description "Select VGA write plane (0-3: Red, Green, Cyan, Status)" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasParameter src:Param_PlaneNum .

src:Proc_SelectFunc a radar:Procedure ;
    rdfs:label "SelectFunc" ;
    dc:description "Set graphics raster operation (ROP) mode" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_GRPlot a radar:Procedure ;
    rdfs:label "GRPlot" ;
    dc:description "Plot individual pixel at coordinates" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasParameter src:Param_X, src:Param_Y .

src:Proc_GRLine a radar:Procedure ;
    rdfs:label "GRLine" ;
    dc:description "Draw line using Bresenham algorithm" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasParameter src:Param_X1, src:Param_Y1, src:Param_X2, src:Param_Y2 .

src:Proc_DispLine a radar:Procedure ;
    rdfs:label "DispLine" ;
    dc:description "Decompress and display radar picture line" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:purpose "Decode RLE compressed line data and render to screen" .

src:Proc_ConOut a radar:Procedure ;
    rdfs:label "ConOut" ;
    dc:description "Output character to screen in graphics mode" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasParameter src:Param_Char .

src:Proc_GRWrite a radar:Procedure ;
    rdfs:label "GRWrite" ;
    dc:description "Write graphical text string to screen" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasParameter src:Param_Text .

src:Proc_Window a radar:Procedure ;
    rdfs:label "Window" ;
    dc:description "Create and manage text window on screen" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_WriteRngMks a radar:Procedure ;
    rdfs:label "WriteRngMks" ;
    dc:description "Draw range circle overlay using lookup tables" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:purpose "Render range markers at 10, 25, 50, 100, 200 nm" .

src:Proc_WriteGfx a radar:Procedure ;
    rdfs:label "WriteGfx" ;
    dc:description "Render landmarks and map segments" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_WriteParams a radar:Procedure ;
    rdfs:label "WriteParams" ;
    dc:description "Display radar parameter values on screen" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_WriteHelp a radar:Procedure ;
    rdfs:label "WriteHelp" ;
    dc:description "Display help screen with command reference" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_ClearScreen a radar:Procedure ;
    rdfs:label "ClearScreen" ;
    dc:description "Clear graphics screen" ;
    radar:belongsToCategory radar:GraphicsCategory ;
    radar:definedIn src:File_RADAR_PAS .

# =============================================================================
# RS-232 Serial Communication (2400 baud)
# =============================================================================

src:Proc_RS232Interrupt a radar:InterruptHandler ;
    rdfs:label "RS232Interrupt" ;
    dc:description "Interrupt service routine for COM port" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:purpose "Handle serial port receive interrupts and buffer data" .

src:Proc_Tx a radar:Procedure ;
    rdfs:label "Tx" ;
    dc:description "Transmit single character over serial port" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasParameter src:Param_Char .

src:Func_Rx a radar:Function ;
    rdfs:label "Rx" ;
    dc:description "Receive character from serial buffer" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasReturnType src:Type_Char .

src:Func_SendCom a radar:Function ;
    rdfs:label "SendCom" ;
    dc:description "Send command and wait for response with timeout" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:hasReturnType src:Type_Boolean ;
    radar:calls src:Proc_Tx, src:Func_Rx .

src:Proc_SetParams a radar:Procedure ;
    rdfs:label "SetParams" ;
    dc:description "Parse radar response and extract parameters" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_InitRS232 a radar:Procedure ;
    rdfs:label "InitRS232" ;
    dc:description "Initialize serial port (8 data, 1 stop, no parity, 2400 baud)" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_ResetBuf a radar:Procedure ;
    rdfs:label "ResetBuf" ;
    dc:description "Clear serial receive buffer" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:definedIn src:File_RADAR_PAS .

