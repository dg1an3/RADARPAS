src:Proc_HangUp a radar:Procedure ;
    rdfs:label "HangUp" ;
    dc:description "Disconnect call by dropping DTR/RTS" ;
    radar:belongsToCategory radar:ModemCategory ;
    radar:definedIn src:File_RADAR_PAS .

