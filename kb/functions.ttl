src:Proc_SetupTxInt a radar:Procedure ;
    rdfs:label "SetupTxInt" ;
    dc:description "Configure transmit interrupt" ;
    radar:belongsToCategory radar:SerialCommCategory ;
    radar:firstSeen "1988-08-15"^^xsd:date ;
    radar:lastSeen "1992-12-28"^^xsd:date ;
    radar:signature "procedure SetupTxInt(...)" .

src:Func_SendCom a radar:Function ;
    rdfs:label "SendCom" ;
    dc:description "Send command and wait for response with timeout" ;
