# =============================================================================
# Modula-2 MAIN Module Procedures (E300PC 3.1)
# =============================================================================

src:Proc_M2_ExecCom a radar:Procedure ;
    rdfs:label "ExecCom" ;
    dc:description "Process regular key codes and execute corresponding commands" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_MAIN_MOD ;
    radar:lineNumber 102 ;
    radar:hasParameter src:Param_Key .

src:Proc_M2_OptionMenu a radar:Procedure ;
    rdfs:label "OptionMenu" ;
    dc:description "Display and manage program options (baud rate, COM port, update interval, clock format)" ;
    radar:belongsToCategory radar:ConfigCategory ;
    radar:definedIn src:File_MAIN_MOD ;
    radar:lineNumber 140 .

src:Proc_M2_DoAuto a radar:Procedure ;
    rdfs:label "DoAuto" ;
    dc:description "Perform automatic picture capture on scheduled interval" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_MAIN_MOD ;
    radar:lineNumber 237 ;
    radar:calls src:Proc_M2_CallStation, src:Proc_M2_MakePic, src:Proc_M2_SavePicture .

src:Proc_M2_InterLoop a radar:Procedure ;
    rdfs:label "InterLoop" ;
    dc:description "Interactive mode loop - connected station with parameter control and picture download" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_MAIN_MOD ;
    radar:lineNumber 432 ;
    radar:calls src:Proc_M2_CallStation, src:Proc_M2_ExecCom .

src:Proc_M2_AutoMenu a radar:Procedure ;
    rdfs:label "AutoMenu" ;
    dc:description "Set automatic update interval via user prompt" ;
    radar:belongsToCategory radar:ConfigCategory ;
    radar:definedIn src:File_MAIN_MOD ;
    radar:lineNumber 749 .

src:Proc_M2_ModemLoop a radar:Procedure ;
    rdfs:label "ModemLoop" ;
    dc:description "Main modem idle state loop with keyboard input and cursor navigation" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_MAIN_MOD ;
    radar:lineNumber 762 ;
    radar:calls src:Proc_M2_DoAuto, src:Proc_M2_ExecCom, src:Proc_M2_InterLoop .

# =============================================================================
# Modula-2 PICTURES Module Procedures
# =============================================================================

src:Proc_M2_FileName a radar:Procedure ;
    rdfs:label "FileName" ;
    dc:description "Generate filename for picture file from PictureRec (time+tilt+range+gain.WX)" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 50 .

src:Proc_M2_FileParam a radar:Procedure ;
    rdfs:label "FileParam" ;
    dc:description "Parse filename to extract picture parameters (reverse of FileName)" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 96 .

src:Proc_M2_SavePicture a radar:Procedure ;
    rdfs:label "SavePicture" ;
    dc:description "Save picture to disk file in station directory" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 136 .

src:Proc_M2_ReserveMem a radar:Procedure ;
    rdfs:label "ReserveMem" ;
    dc:description "Allocate memory for picture, purging oldest pictures if needed" ;
    radar:belongsToCategory radar:FileIOCategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 176 ;
    radar:calls src:Proc_M2_SavePicture .

src:Proc_M2_SelectPicture a radar:Procedure ;
    rdfs:label "SelectPicture" ;
    dc:description "Display indicated picture, loading from disk if needed" ;
    radar:belongsToCategory radar:UICategory ;
    radar:definedIn src:File_PICTURES_MOD ;
    radar:lineNumber 244 ;
