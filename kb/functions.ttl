# =============================================================================
# Modem Control
# =============================================================================

src:Proc_CallStation a radar:Procedure ;
    rdfs:label "CallStation" ;
    dc:description "Dial station via Hayes or Racal-Vadic modem" ;
    radar:belongsToCategory radar:ModemCategory ;
    radar:definedIn src:File_RADAR_PAS ;
