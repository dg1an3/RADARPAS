src:Proc_DeInit a radar:Procedure ;
    rdfs:label "DeInit" ;
    dc:description "Shutdown cleanup and resource release" ;
    radar:belongsToCategory radar:ConfigCategory ;
    radar:definedIn src:File_RADAR_PAS .

# =============================================================================
# Main Control Loops
# =============================================================================

src:Proc_ModemLoop a radar:Procedure ;
    rdfs:label "ModemLoop" ;
    dc:description "Main loop for modem idle state" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_InterLoop a radar:Procedure ;
    rdfs:label "InterLoop" ;
    dc:description "Connected/interactive mode loop with parameter control" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_RADAR_PAS .

src:Proc_RxPicLoop a radar:Procedure ;
    rdfs:label "RxPicLoop" ;
    dc:description "Main picture reception loop" ;
    radar:belongsToCategory radar:ProtocolCategory ;
    radar:definedIn src:File_RADAR_PAS ;
