# =============================================================================
# RADARPAS Symbol Occurrences
#
# Each SymbolOccurrence binds an abstract symbol to a specific archive/file.
# Focused on 4 key snapshots where symbols change:
#   1985xxxx  — Genesis (Turbo Pascal monolith)
#   19871102  — Pas2Mod2 pivot
#   19880815  — Full Modula-2 release
#   19921228  — Final E300PC 3.1
# Plus intermediate snapshots where specific symbols first appear or change.
# =============================================================================

# =============================================================================
# 1. Graphics & Display
# =============================================================================

# --- InitEGA ---
src:Occ_InitEGA_1985 a radar:SymbolOccurrence ;
    rdfs:label "InitEGA @ 1985" ;
    radar:ofSymbol src:Proc_InitEGA ;
    radar:inArchive src:Archive_1985xxxx ;
    radar:definedIn src:File_RADAR_PAS ;
    radar:programmingLanguage "Turbo Pascal" .

src:Occ_InitEGA_19880815 a radar:SymbolOccurrence ;
    rdfs:label "InitEGA @ 1988-08-15" ;
    radar:ofSymbol src:Proc_InitEGA ;
    radar:inArchive src:Archive_19880815 ;
    radar:inModule src:Module_GRAPHICS ;
    radar:definedIn src:File_GRAPHICS_MOD ;
    radar:succeeds src:Occ_InitEGA_1985 ;
    radar:programmingLanguage "Modula-2" .

