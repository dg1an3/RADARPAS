procedure SetDate(var ForDay : DateRec);
var     Dateinput  : string[8];
        Timeinput  : string[8];
        Right      : boolean;
        Number     : integer;
        NextChar   : integer;
begin   Frame(30, 12, 50, 15);
        ClrScr;
        Cursor(0,7);
        GotoXY(1,1);
        Write('DATE: ');
        Readln(StrA);
        GotoXY(1,2);
        Write('TIME: ');
        Readln(StrB);
        ParseDate(StrA, StrB, TodaysDate, Right);
        Cursor(16,0);
end (* SetDate *);

procedure Quit;
begin   Password := '';
        Cursor(6,7);
        ClrScr;
end (* Quit *);

var     key  : char;
        escFlag  : boolean;
        NxtProg  : file;
begin   TextColor(NORM_COLOR);
        TextBackground(NORM_BACKG);
        Cursor(16, 0);
        Window(1,1,80,25);
        ClrScr;
        ChangeStatus := true;
        ChangeWindow(MainMenu);
        if (DateEntered <> 147) then begin
            GetSysDate(TodaysDate);
            if (TodaysDate.year < 1984) then
                SetDate(TodaysDate);
            DateEntered := 147;
            Infoline;
            if IsNewYear then
                NewYear;
            (* else
                CheckForOldData; *)
        end else
            Infoline;
        GotoXY(1, 24);
        repeat
            ReadKbd(key, escFlag);
            case key of
                KEY_F1  : Assign(NxtProg, 'FIM.CHN');
                KEY_F2  : Assign(NxtProg, 'IA.CHN');
                KEY_F3  : Assign(NxtProg, 'AP.CHN');
                KEY_F4  : Assign(NxtProg, 'AR.CHN');
                KEY_F5  : Assign(NxtProg, 'MAIL.CHN');
                KEY_F6  : Assign(NxtProg, 'DR.CHN');
                KEY_F7  : Backup;
                KEY_F8  : Restore;
                'd'  : begin
                           SetDate(TodaysDate);
                           ChangeWindow(MainMenu);
                           InfoLine;
                           GotoXY(1, 24);
                           ClrEol;
                       end;
            end (* case *);
            if key in [KEY_F1..KEY_F6] then begin
                Chain(NxtProg);
                if (IOResult = $01) then begin
                    ErrorMsg('Program file not found.  ' +
                        'Please contact software vendor');
                    ChangeWindow(MainMenu);
                end (* if *);
            end (* if *);
        until (Key = KEY_ESC);
        Quit;
end (* Menu *).