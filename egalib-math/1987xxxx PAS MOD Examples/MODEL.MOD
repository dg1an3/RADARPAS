MODEL BYTE;
  ARRAY[0..7] OF BIT;
END BYTE;

MODEL CHAR;
  ARRAY[0..7] OF BIT;
END CHAR;

MODEL INTEGER;
  SIGN : BIT;
  MANT : ARRAY[0..14] OF BIT;
END INTEGER;

MODEL REAL;
  SIGN : BIT;
  EXP  : ARRAY[0..6] OF BIT;
  MANT : ARRAY[0..39] OF BIT;
END REAL;

MODEL 
  CASE OpCode : CARDINAL OF
    00H : 
